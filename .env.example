# ─────────────────────────────────────────────────────────────────
# Meridian — environment variables
# Copy to .env.local (web) or set as VPS / GitHub Actions secrets.
# ─────────────────────────────────────────────────────────────────

# Public site URL used for canonical links, OG images, citations.
NEXT_PUBLIC_SITE_URL=https://meridian.ai

# Optional Postgres (Neon). When unset, the app serves static fixtures.
# Get one free at https://neon.tech
# DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/meridian?sslmode=require

# Admin token guards /v1/admin/* and /v1/webhooks/drain.
# Generate with: openssl rand -hex 32
# ADMIN_TOKEN=replace-me-with-a-long-random-string

# GitHub token for the crawler (optional — raises the rate limit).
# Needs: public_repo, read:user. Store in GitHub Actions as GH_DISCOVERY_TOKEN.
# GITHUB_TOKEN=...

# For the webhook-drain GH Action — where to call:
# MERIDIAN_URL=https://meridian.ai
