{
  "name": "@meridian/sdk",
  "version": "2.0.0",
  "description": "Meridian SDK — open-source, zero-cost, minimally invasive middleware for AI agents. Reports behavioral telemetry to Meridian (no task content, no user data) and exposes a /meridian/compliance endpoint.",
  "license": "MIT",
  "author": "The Meridian Standards Body",
  "homepage": "https://meridian.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omerperchik/Meridian.git",
    "directory": "sdk/typescript"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "meridian",
    "ai-agent",
    "agent-trust",
    "uaop",
    "atp",
    "telemetry",
    "compliance",
    "observability",
    "safety"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
